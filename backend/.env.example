# Database
DATABASE_URL=postgresql://user:password@localhost:5432/realtradenews
REDIS_URL=redis://localhost:6379

# Server
NODE_ENV=development
PORT=3000
JWT_SECRET=your_jwt_secret_key_change_in_production

# Payment
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_test_your_key

# APIs
TRADING_ECONOMICS_API_KEY=your_key
POLYGON_API_KEY=your_key

# Email/Notifications
SENDGRID_API_KEY=your_key
FIREBASE_CONFIG={"apiKey":"..."}

# External APIs
YAHOO_FINANCE_ENDPOINT=https://es.finance.yahoo.com
INVESTING_COM_ENDPOINT=https://www.investing.com

# Cors
FRONTEND_URL=http://localhost:3000
MOBILE_APP_URL=com.realtradenews.app
